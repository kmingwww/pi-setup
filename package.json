{
  "name": "pi-setup",
  "version": "0.1.0",
  "description": "A collection of core pi extensions including delegate-task, ask-user-question, and notify.",
  "keywords": [
    "pi-package",
    "swarm",
    "agent",
    "delegate",
    "ask",
    "notify"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "scripts": {
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "git config --local core.hooksPath .githooks"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@earendil-works/pi-tui": "^0.79.4",
    "@eslint/js": "~10.0.1",
    "eslint": "~10.5.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-prettier": "~5.5.6",
    "prettier": "~3.8.4",
    "typebox": "^1.1.38",
    "typescript": "^6.0.3",
    "typescript-eslint": "~8.61.1",
    "vitest": "^4.1.9"
  },
  "pi": {
    "extensions": [
      "./extensions/*"
    ]
  }
