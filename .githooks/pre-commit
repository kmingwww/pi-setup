#!/bin/sh

echo "🔍 Running Prettier, ESLint, and tests..."

# Run formatting and linting
npm run format
npm run lint

# Capture the exit code of lint
LINT_CODE=$?

if [ $LINT_CODE -ne 0 ]; then
  echo "❌ Linting failed! Please fix the errors before committing."
  exit 1
fi

# Run tests
npm run test

# Capture the exit code of test
TEST_CODE=$?

if [ $TEST_CODE -ne 0 ]; then
  echo "❌ Tests failed! Please fix the errors before committing."
  exit 1
fi

# Re-stage any files that Prettier just modified
# (Only updates files that are already tracked and have changes)
git add -u

echo "✅ All checks passed!"
